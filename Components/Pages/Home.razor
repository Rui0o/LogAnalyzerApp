@page "/"
@using LogAnalyzerApp.Models
@using LogAnalyzerApp.Services
@using System.IO
@inject LogProcessorService LogProcessor
@inject DownloadFileService DownloadService
@inject UploadFileService UploadService
@inject AppStateService AppState
@inject IJSRuntime JS
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>LogAnalyzer - Dashboard</PageTitle>

<div class="container-fluid py-4" style="max-width: 1200px;">

    <!-- Upload Zone -->
    <div class="upload-zone @(availableTags.Any() ? "has-file" : "") mb-3"
         @ondragover:preventDefault @ondrop:preventDefault>
        <InputFile @ref="fileInput" OnChange="HandleFileSelected" class="upload-input" disabled="@isProcessing" />
        @if (availableTags.Any()) {
            <div>
                <i class="bi bi-check-circle text-success me-2"></i>
                <span class="fw-bold">@loadedFileName</span>
                <span class="text-muted ms-2" style="font-size:0.8rem;">— drop a new file to replace</span>
            </div>
        } else {
            <div>
                <i class="bi bi-cloud-arrow-up d-block mb-2" style="font-size:2.5rem; color:var(--accent); opacity:0.7;"></i>
                <span class="fw-bold" style="font-size:1.05rem;">Drop a logcat file here</span>
                <span class="d-block text-muted mt-1" style="font-size:0.8rem;">or click to browse &nbsp;·&nbsp; up to 500 MB</span>
            </div>
        }
    </div>

    <!-- Progress bar (inline, below upload zone) -->
    @if (isProcessing || isGenerating) {
        <div class="progress-wrap mb-3">
            <div class="d-flex justify-content-between mb-2" style="font-size:0.82rem;">
                <span class="text-muted">@statusMessage</span>
                @if (!isAnalyzing && !isGenerating) {
                    <span class="text-muted">@progress%</span>
                }
            </div>
            <div class="progress">
                @if (isAnalyzing || isGenerating) {
                    <div class="progress-bar progress-bar-striped progress-bar-animated"
                         role="progressbar" style="width:100%"></div>
                } else {
                    <div class="progress-bar progress-bar-striped progress-bar-animated"
                         role="progressbar" style="width:@progress%"></div>
                }
            </div>
        </div>
    }

    <!-- Filters (visible after file load) -->
    @if (availableTags.Any()) {
        <div class="filters-section mb-3">
            <!-- Header row -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="fw-bold" style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.06em; color:var(--text-muted);">
                    <i class="bi bi-funnel me-1"></i> Filters
                </span>
                @if (selectedTags.Any() || selectedLevels.Any() || !string.IsNullOrWhiteSpace(keywordFilter)) {
                    <button class="btn-clear" @onclick="ClearAllFilters">
                        <i class="bi bi-x me-1"></i>Clear all (@(selectedTags.Count + selectedLevels.Count + (string.IsNullOrWhiteSpace(keywordFilter) ? 0 : 1)))
                    </button>
                }
            </div>

            <!-- Level pills -->
            <div class="d-flex flex-wrap gap-2 mb-3">
                @foreach (var level in availableLevels) {
                    var levelCss = GetLevelCss(level);
                    var isActive = selectedLevels.Contains(level);
                    var count = levelCounts.GetValueOrDefault(level, 0);
                    <button class="level-pill @levelCss @(isActive ? "active" : "")"
                            @onclick="() => ToggleLevelClick(level)">
                        @level <span class="level-pill-count">@count</span>
                    </button>
                }
            </div>

            <!-- Search -->
            <div class="search-wrapper mb-3">
                <i class="bi bi-search search-icon" style="font-size:0.8rem;"></i>
                <input type="text" class="search-input"
                       placeholder="Search @availableTags.Count tags..."
                       @bind="tagSearchQuery" @bind:event="oninput" />
                @if (!string.IsNullOrWhiteSpace(tagSearchQuery) && FilteredTags.Any()) {
                    <button class="btn-select-filtered" @onclick="SelectFiltered">
                        Select all (@FilteredTags.Count())
                    </button>
                }
            </div>

            <!-- Tag chips -->
            <div class="d-flex justify-content-between align-items-center mb-2" style="font-size:0.75rem; color:var(--text-muted);">
                <span>
                    @if (!string.IsNullOrWhiteSpace(tagSearchQuery)) {
                        <span>@FilteredTags.Count() of @availableTags.Count tags</span>
                    } else {
                        <span>@availableTags.Count tags</span>
                    }
                </span>
                @if (selectedTags.Any()) {
                    <span style="color:#a5b4fc;">@selectedTags.Count selected</span>
                }
            </div>
            <div class="tag-chips-wrap">
                @foreach (var tag in FilteredTags) {
                    var isActive = selectedTags.Contains(tag);
                    <button class="tag-chip @(isActive ? "active" : "")"
                            title="@tag"
                            @onclick="() => ToggleTagClick(tag)">
                        @if (!string.IsNullOrEmpty(tagSearchQuery) && tag.Contains(tagSearchQuery, StringComparison.OrdinalIgnoreCase)) {
                            <strong>@tag</strong>
                        } else {
                            @tag
                        }
                    </button>
                }
                @if (!FilteredTags.Any()) {
                    <span class="text-muted" style="font-size:0.82rem;">No tags match "@tagSearchQuery"</span>
                }
            </div>

            <!-- Keyword filter -->
            <div class="search-wrapper mt-3">
                <i class="bi bi-type search-icon" style="font-size:0.8rem;"></i>
                <input type="text" class="search-input"
                       placeholder="Keywords: com.example.app, SomeService, ..."
                       @bind="keywordFilter" @bind:event="oninput" />
                @if (!string.IsNullOrWhiteSpace(keywordFilter)) {
                    <button class="btn-select-filtered" @onclick="() => keywordFilter = string.Empty">
                        <i class="bi bi-x"></i>
                    </button>
                }
            </div>
        </div>

        <!-- Action bar -->
        <div class="action-bar mb-3">
            <label>Context</label>
            <div class="context-stepper">
                <button @onclick="() => contextLines = Math.Max(0, contextLines - 1)">−</button>
                <input type="number" class="context-input" @bind="contextLines" @bind:after="ClampContextLines" min="0" max="50" />
                <button @onclick="() => contextLines = Math.Min(50, contextLines + 1)">+</button>
            </div>

            <div class="direction-toggle">
                <button class="dir-btn @(contextDirection == ContextDirection.Before ? "active" : "")"
                        @onclick='() => contextDirection = ContextDirection.Before'>Before</button>
                <button class="dir-btn @(contextDirection == ContextDirection.After ? "active" : "")"
                        @onclick='() => contextDirection = ContextDirection.After'>After</button>
                <button class="dir-btn @(contextDirection == ContextDirection.Both ? "active" : "")"
                        @onclick='() => contextDirection = ContextDirection.Both'>Both</button>
            </div>

            <button class="separator-toggle @(useSeparator ? "active" : "")"
                    @onclick='() => useSeparator = !useSeparator'
                    title="Insert separator between result groups">
                <i class="bi bi-layout-split me-1"></i>Separator
            </button>

            @if (selectedTags.Any() || selectedLevels.Any() || !string.IsNullOrWhiteSpace(keywordFilter)) {
                <span class="filter-count-badge">@(selectedTags.Count + selectedLevels.Count + (string.IsNullOrWhiteSpace(keywordFilter) ? 0 : 1)) filters</span>
            }

            <button class="btn-generate"
                    @onclick="GenerateAndDownload"
                    disabled="@(isProcessing || isGenerating || (!selectedTags.Any() && !selectedLevels.Any() && string.IsNullOrWhiteSpace(keywordFilter)))">
                <i class="bi bi-gear-fill me-1"></i> Generate Report
            </button>
        </div>
    } else if (!isProcessing) {
        <!-- Empty state -->
        <div class="empty-state mb-3">
            <i class="bi bi-inbox empty-icon"></i>
            <p class="mb-0" style="font-size:0.9rem;">Upload a logcat file to see filters</p>
        </div>
    }

    <!-- Debug Terminal -->
    <div class="debug-terminal">
        <div class="terminal-header">
            <span><i class="bi bi-terminal me-2"></i>ANALYSIS LOGS</span>
            <span style="font-size:0.7rem; color:var(--text-muted); font-weight:400;">@debugLogs.Count entries</span>
        </div>
        <div class="terminal-body">
            @foreach (var log in debugLogs) {
                <div class="log-line">
                    <span class="log-ts">[@log.Timestamp.ToString("HH:mm:ss")]</span>
                    <span class="log-msg @(log.Message.StartsWith("ERROR") ? "error" : "")">@log.Message</span>
                </div>
            }
        </div>
    </div>
</div>

<script>
    window.uploadFileXhr = (inputEl, dotNetRef) => {
        const file = inputEl.files[0];
        if (!file) {
            dotNetRef.invokeMethodAsync('OnUploadError', 'No file selected');
            return;
        }
        const xhr = new XMLHttpRequest();
        const form = new FormData();
        form.append('file', file);
        let lastUpdate = 0;
        xhr.upload.addEventListener('progress', e => {
            if (!e.lengthComputable) return;
            const now = Date.now();
            if (now - lastUpdate < 100) return;
            lastUpdate = now;
            const pct = Math.round(e.loaded * 100 / e.total);
            dotNetRef.invokeMethodAsync('OnUploadProgress', e.loaded, e.total, pct);
        });
        xhr.addEventListener('load', () => {
            if (xhr.status === 200) {
                dotNetRef.invokeMethodAsync('OnUploadDone', xhr.responseText.trim());
            } else {
                dotNetRef.invokeMethodAsync('OnUploadError', 'Upload failed: ' + xhr.status);
            }
        });
        xhr.addEventListener('error', () => {
            dotNetRef.invokeMethodAsync('OnUploadError', 'Network error during upload');
        });
        xhr.open('POST', '/upload');
        xhr.send(form);
    };

    window.downloadFromUrl = async (url, filename) => {
        try {
            const response = await fetch(url);
            if (!response.ok) {
                console.error('Download failed:', response.status, response.statusText);
                return;
            }
            const blob = await response.blob();
            const blobUrl = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = blobUrl;
            link.download = filename;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            setTimeout(() => URL.revokeObjectURL(blobUrl), 100);
        } catch (e) {
            console.error('Download error:', e);
        }
    };
</script>

@code {
    private record DebugLogEntry(string Message, DateTime Timestamp);
    private List<DebugLogEntry> debugLogs = new();

    private InputFile? fileInput;
    private DotNetObjectReference<Home>? _dotNetRef;
    private string? tempFilePath;
    private string loadedFileName = "";
    private List<string> availableTags = new();
    private List<string> availableLevels = new();
    private Dictionary<string, int> levelCounts = new();
    private List<string> selectedTags = new();
    private List<string> selectedLevels = new();
    private string tagSearchQuery = "";
    private string keywordFilter = "";
    private int contextLines = 10;
    private ContextDirection contextDirection = ContextDirection.Before;
    private bool useSeparator = false;
    private bool isProcessing = false;
    private bool isAnalyzing = false;
    private bool isGenerating = false;
    private int progress = 0;
    private string statusMessage = "";

    private IEnumerable<string> FilteredTags =>
        string.IsNullOrWhiteSpace(tagSearchQuery)
            ? availableTags.Take(1000)
            : availableTags.Where(t => t.Contains(tagSearchQuery, StringComparison.OrdinalIgnoreCase)).Take(500);

    private void AddLog(string msg) {
        debugLogs.Add(new DebugLogEntry(msg, DateTime.Now));
    }

    private void ClearAllFilters() {
        selectedTags.Clear();
        selectedLevels.Clear();
        keywordFilter = "";
    }

    private void ClampContextLines() {
        contextLines = Math.Clamp(contextLines, 0, 50);
    }

    private void ToggleLevelClick(string level) {
        if (selectedLevels.Contains(level)) selectedLevels.Remove(level);
        else selectedLevels.Add(level);
    }

    private void ToggleTagClick(string tag) {
        if (selectedTags.Contains(tag)) selectedTags.Remove(tag);
        else selectedTags.Add(tag);
    }

    private void SelectFiltered() {
        foreach (var tag in FilteredTags)
            if (!selectedTags.Contains(tag)) selectedTags.Add(tag);
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        try {
            isProcessing = true;
            isAnalyzing = false;
            progress = 0;
            statusMessage = "Uploading...";
            loadedFileName = e.File.Name;
            debugLogs.Clear();
            availableTags.Clear();
            availableLevels.Clear();
            selectedTags.Clear();
            selectedLevels.Clear();

            AddLog($"Loading file: {e.File.Name}");
            StateHasChanged();

            DeleteTempFile();

            _dotNetRef?.Dispose();
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("uploadFileXhr", fileInput!.Element, _dotNetRef);
        } catch (Exception ex) {
            AddLog($"ERROR: {ex.Message}");
            isProcessing = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task OnUploadProgress(long loaded, long total, int pct)
    {
        progress = pct;
        statusMessage = $"Uploading: {loaded / 1024 / 1024} / {total / 1024 / 1024} MB";
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnUploadDone(string token)
    {
        try {
            var path = UploadService.GetAndRemove(token);
            if (path == null) {
                AddLog("ERROR: Upload token invalid");
                isProcessing = false;
                await InvokeAsync(StateHasChanged);
                return;
            }
            tempFilePath = path;
            AddLog("File uploaded. Scanning tags and levels...");
            isAnalyzing = true;
            statusMessage = "Analyzing...";
            await InvokeAsync(StateHasChanged);

            using var fs = new FileStream(tempFilePath, FileMode.Open, FileAccess.Read, FileShare.Read);
            var result = await LogProcessor.ExtractUniqueTagsAndLevelsAsync(fs);
            availableTags = result.Tags;
            availableLevels = result.Levels;
            levelCounts = result.LevelCounts;

            AddLog($"Analysis complete. Found {availableTags.Count} tags, {availableLevels.Count} levels.");
            AppState.SetFileInfo(loadedFileName, availableTags.Count, availableLevels.Count);
            statusMessage = "Ready!";
        } catch (Exception ex) {
            AddLog($"ERROR: {ex.Message}");
        } finally {
            isProcessing = false;
            isAnalyzing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    [JSInvokable]
    public async Task OnUploadError(string error)
    {
        AddLog($"ERROR: {error}");
        isProcessing = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task GenerateAndDownload()
    {
        if (string.IsNullOrEmpty(tempFilePath) || isGenerating) return;

        isGenerating = true;
        statusMessage = "Generating extract...";
        StateHasChanged();

        string? outputTempPath = null;
        try {
            var kw = keywordFilter?.Trim();
            var kwDisplay = string.IsNullOrWhiteSpace(kw) ? "none" : kw;
            AddLog($"Generating extract (Tags: {selectedTags.Count}, Levels: {selectedLevels.Count}, Keyword: {kwDisplay}, Context: {contextLines} lines)...");

            outputTempPath = Path.GetTempFileName();

            using (var inputFs = new FileStream(tempFilePath, FileMode.Open, FileAccess.Read, FileShare.Read))
            using (var outputFs = new FileStream(outputTempPath, FileMode.Create, FileAccess.Write, FileShare.None))
            {
                await LogProcessor.GenerateFilteredLogAsync(inputFs, outputFs, selectedTags, selectedLevels, contextLines, contextDirection, useSeparator, kw);
            }

            var token = DownloadService.RegisterFile(outputTempPath);
            outputTempPath = null;
            await JS.InvokeVoidAsync("downloadFromUrl", $"/download/{token}", "log_extract.txt");
            AddLog("Download started.");
        } catch (Exception ex) {
            AddLog($"ERROR: {ex.Message}");
            if (outputTempPath != null)
            {
                try { File.Delete(outputTempPath); } catch { /* best-effort */ }
            }
        } finally {
            isGenerating = false;
            statusMessage = "";
            StateHasChanged();
        }
    }

    private void DeleteTempFile()
    {
        if (!string.IsNullOrEmpty(tempFilePath))
        {
            try { File.Delete(tempFilePath); } catch { /* best-effort */ }
            tempFilePath = null;
        }
    }

    public void Dispose()
    {
        DeleteTempFile();
        _dotNetRef?.Dispose();
    }

    private string GetLevelCss(string level) => level switch {
        "Verbose"     => "lvl-verbose",
        "Debug"       => "lvl-debug",
        "Information" => "lvl-info",
        "Warning"     => "lvl-warning",
        "Error"       => "lvl-error",
        "Fatal"       => "lvl-fatal",
        _             => "lvl-info"
    };

    private string GetBadgeClass(string level) => level switch {
        "Verbose"     => "bg-secondary",
        "Debug"       => "bg-info text-dark",
        "Information" => "bg-success",
        "Warning"     => "bg-warning text-dark",
        "Error"       => "bg-danger",
        "Fatal"       => "bg-dark",
        _             => "bg-primary"
    };
}
